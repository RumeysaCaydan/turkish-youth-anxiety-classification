import os
import argparse

import numpy as np
import torch
import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt
from transformers import AutoModelForSequenceClassification, AutoTokenizer
from sklearn.metrics import (
    classification_report,
    confusion_matrix,
    accuracy_score,
)

from preprocessing import X_test, y_test, label_names


def _annotate_bars(ax, fmt="{:.3f}"):
    for p in ax.patches:
        h = p.get_height()
        if h is None:
            continue
        ax.annotate(
            fmt.format(h),
            (p.get_x() + p.get_width() / 2.0, h),
            ha="center",
            va="bottom",
            fontsize=9,
            xytext=(0, 3),
            textcoords="offset points",
        )


def plot_per_category_bars(
    df,
    x_col,
    y_col,
    title,
    y_label,
    save_path,
    fmt="{:.3f}",
    ylim=(0.0, 1.05),
    figsize=(12, 5),
    rotation=30,
):
    """Kategoriler bazinda metric karsilastirmasi yapan bar grafikleri."""
    plt.figure(figsize=figsize)
    ax = sns.barplot(x=x_col, y=y_col, data=df)
    ax.set_title(title)
    ax.set_xlabel("Kategori")
    ax.set_ylabel(y_label)
    ax.set_ylim(*ylim)
    _annotate_bars(ax, fmt=fmt)
    plt.xticks(rotation=rotation, ha="right")
    plt.tight_layout()
    plt.savefig(save_path, dpi=200)
    plt.close()


def plot_confusion_matrix(cm, labels, save_path):
    """Confusion matrix heatmap grafiğini tek fonksiyonda ciz."""
    plt.figure(figsize=(10, 9))
    sns.heatmap(
        cm,
        annot=True,
        fmt="d",
        cmap="RdPu",
        xticklabels=labels,
        yticklabels=labels,
    )
    plt.title("Confusion Matrix")
    plt.xlabel("Tahmin Edilen Sinif")
    plt.ylabel("Gercek Sinif")
    plt.tight_layout()
    plt.savefig(save_path, dpi=200)
    plt.close()


def predict(model, tokenizer, device, texts, max_length=128):
    preds = []
    for text in texts:
        inputs = tokenizer(
            str(text),
            return_tensors="pt",
            truncation=True,
            padding=True,
            max_length=max_length,
        ).to(device)
        with torch.no_grad():
            outputs = model(**inputs)
            pred = torch.argmax(outputs.logits, dim=-1).item()
            preds.append(pred)
    return preds


def one_vs_rest_accuracy(y_true, y_pred, n_classes):
    """
    Her kategori icin one-vs-rest yaklasimiyla accuracy hesaplar:
    - y_true_bin: (y==i)
    - y_pred_bin: (y_pred==i)
    """
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)
    accs = []
    for i in range(n_classes):
        y_true_bin = (y_true == i).astype(int)
        y_pred_bin = (y_pred == i).astype(int)
        accs.append(accuracy_score(y_true_bin, y_pred_bin))
    return accs


def main():
    parser = argparse.ArgumentParser(
        description="Kategori bazinda F1-score ve accuracy metriklerini grafiksellestir."
    )
    parser.add_argument(
        "--model-path",
        default="./results/checkpoint-327",
        help="Fine-tuned model klasoru (HuggingFace checkpoint).",
    )
    parser.add_argument(
        "--max-length",
        type=int,
        default=128,
        help="Tokenizer icin max sequence length.",
    )
    parser.add_argument(
        "--save-dir",
        default="./results/figures",
        help="Grafiklerin kaydedilecegi klasor.",
    )
    args = parser.parse_args()

    os.makedirs(args.save_dir, exist_ok=True)

    device = "cuda" if torch.cuda.is_available() else "cpu"

    print(f"Model yukleniyor: {args.model_path}")
    tokenizer = AutoTokenizer.from_pretrained("dbmdz/bert-base-turkish-cased")
    model = AutoModelForSequenceClassification.from_pretrained(args.model_path)
    model.to(device)
    model.eval()

    y_true = y_test.tolist() if hasattr(y_test, "tolist") else list(y_test)
    y_true_arr = np.asarray(y_true)
    n_classes = len(label_names)

    print(f"Test ediliyor: {len(X_test)} ornek")
    y_pred = predict(
        model=model,
        tokenizer=tokenizer,
        device=device,
        texts=X_test,
        max_length=args.max_length,
    )
    y_pred_arr = np.asarray(y_pred)

    # overall + per-class metrikleri dict formatinda aliyoruz.
    report = classification_report(
        y_true_arr,
        y_pred_arr,
        labels=list(range(n_classes)),
        target_names=label_names,
        output_dict=True,
        zero_division=0,
    )

    overall_accuracy = float(report["accuracy"])
    f1_per_class = [float(report[c]["f1-score"]) for c in label_names]
    one_vs_rest_acc = one_vs_rest_accuracy(y_true_arr, y_pred_arr, n_classes)

    # Veri tablolari
    f1_df = pd.DataFrame({"kategori": label_names, "f1_score": f1_per_class})
    acc_df = pd.DataFrame({"kategori": label_names, "accuracy_ovr": one_vs_rest_acc})

    # 1) F1-score (kategori bazli)
    f1_path = os.path.join(args.save_dir, "f1_score_per_category.png")
    plot_per_category_bars(
        df=f1_df,
        x_col="kategori",
        y_col="f1_score",
        title=f"Kategori Bazli F1-score (Overall accuracy: {overall_accuracy:.4f})",
        y_label="F1-score",
        save_path=f1_path,
        fmt="{:.3f}",
    )
    print(f"Kaydedildi: {f1_path}")

    # 2) One-vs-Rest accuracy (kategori bazli)
    acc_path = os.path.join(args.save_dir, "accuracy_per_category_ovr.png")
    plot_per_category_bars(
        df=acc_df,
        x_col="kategori",
        y_col="accuracy_ovr",
        title="Kategori Bazli (One-vs-Rest) Accuracy",
        y_label="Accuracy",
        save_path=acc_path,
        fmt="{:.3f}",
    )
    print(f"Kaydedildi: {acc_path}")

    # 3) Confusion matrix
    cm = confusion_matrix(y_true_arr, y_pred_arr, labels=list(range(n_classes)))
    cm_path = os.path.join(args.save_dir, "confusion_matrix.png")
    plot_confusion_matrix(cm=cm, labels=label_names, save_path=cm_path)
    print(f"Kaydedildi: {cm_path}")

    # Kisa rapor
    print("\n=== Genel ===")
    print(f"Overall accuracy: {overall_accuracy:.4f}")
    print("=== Per-kategori F1 (sadece ozet) ===")
    for k, v in zip(label_names, f1_per_class):
        print(f"{k}: F1={v:.4f}")


if __name__ == "__main__":
    main()
